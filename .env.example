# ============================================================
# eSIM Shop – Environment Variables
# Copy this file to .env.local for local development.
# In production, set these in the Render dashboard.
# NEVER commit .env.local or any file containing real secrets.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key – NEVER expose to the browser (server-only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── esimaccess API ────────────────────────────────────────────
# https://www.esimaccess.com – get your API credentials there
ESIMACCESS_API_URL=https://api.esimaccess.com/api/v1
ESIMACCESS_ACCESS_CODE=your-esimaccess-access-code

# ── Sellauth ─────────────────────────────────────────────────
# https://sellauth.com – get your keys from the dashboard
SELLAUTH_API_KEY=your-sellauth-api-key
SELLAUTH_SHOP_ID=your-sellauth-shop-id
# Secret used to verify incoming webhook signatures
SELLAUTH_WEBHOOK_SECRET=your-sellauth-webhook-secret

# ── E-Mail (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM_NAME=eSIM Shop
SMTP_FROM_ADDRESS=noreply@example.com

# ── Exchange Rate API (optional) ─────────────────────────────
# If set, the cron job will fetch a live USD/EUR rate from this endpoint.
# Response must include a field "rates.EUR" (Open Exchange Rates format).
# Leave empty to use the fallback rate stored in system_settings.
EXCHANGE_RATE_API_URL=https://open.er-api.com/v6/latest/USD
EXCHANGE_RATE_API_KEY=

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Secret used to protect the /api/cron/* endpoints from public access
CRON_SECRET=your-random-cron-secret-min-32-chars

# ── Node ──────────────────────────────────────────────────────
NODE_ENV=development
