# ============================================================
# eSIM Shop – Environment Variables
# Copy this file to .env.local for local development.
# In production, set these in the Render dashboard.
# NEVER commit .env.local or any file containing real secrets.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key – NEVER expose to the browser (server-only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── esimaccess API ────────────────────────────────────────────
# https://www.esimaccess.com – get your API credentials there
ESIMACCESS_API_URL=https://api.esimaccess.com/api/v1/open
ESIMACCESS_ACCESS_CODE=your-esimaccess-access-code

# ── E-Mail (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM_NAME=eSIM Shop
SMTP_FROM_ADDRESS=noreply@example.com

# ── Exchange Rate API (optional) ─────────────────────────────
# If set, the cron job will fetch a live USD/EUR rate from this endpoint.
# Response must include a field "rates.EUR" (Open Exchange Rates format).
# Leave empty to use the fallback rate stored in system_settings.
EXCHANGE_RATE_API_URL=https://open.er-api.com/v6/latest/USD
EXCHANGE_RATE_API_KEY=

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Secret used to protect the /api/cron/* endpoints from public access
CRON_SECRET=your-random-cron-secret-min-32-chars

# ── Admin ─────────────────────────────────────────────────────
# The e-mail address of the Supabase auth user that gets admin access.
# Log in via /login with this account to reach /admin.
ADMIN_EMAIL=admin@example.com
# Same value exposed to the browser so the login page can redirect to /admin directly.
NEXT_PUBLIC_ADMIN_EMAIL=admin@example.com

# ── pure-wallet ───────────────────────────────────────────────
PURE_WALLET_URL=http://localhost:7777
SHOP_WEBHOOK_SECRET=your-secure-webhook-secret

# ── DeepSeek API ──────────────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
